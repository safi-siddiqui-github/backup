{
  "name": "next-15-ecommerce-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "commit": "git add . && git commit -m",
    "push": "git add . && git commit -m 'update' && git push",
    "sanity": "npx -y sanity@latest",
    "sanity-schema": "sanity schema extract",
    "sanity-types": "sanity typegen generate",
    "typegen": "npx sanity@latest schema extract && npx sanity@latest typegen generate",
    "stripe-webhook": "stripe listen --forward-to localhost:3000/webhook",
    "stripe-trigger": "stripe trigger checkout.session.completed"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.9.2",
    "@sanity/client": "^6.24.1",
    "@sanity/icons": "^3.5.2",
    "@sanity/image-url": "^1.1.0",
    "@sanity/types": "^3.67.1",
    "@sanity/vision": "^3.67.1",
    "@stripe/react-stripe-js": "^3.1.1",
    "@stripe/stripe-js": "^5.4.0",
    "motion": "^11.15.0",
    "next": "15.1.0",
    "next-sanity": "^9.8.27",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "sanity": "^3.67.1",
    "server-only": "^0.0.1",
    "stripe": "^17.5.0",
    "styled-components": "^6.1.13",
    "zustand": "^5.0.2"
  },
  "packageManager": "npm@10.5.2",
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "next": "$next"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
