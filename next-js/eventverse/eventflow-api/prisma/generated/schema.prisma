generator client {
  provider = "prisma-client-js"
  output   = "./generated"
  //   binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  clerkId        String          @unique
  email          String          @unique
  firstname      String?
  lastname       String?
  //
  events         Event[]
  formFieldTypes FormFieldType[]
  //
  createdAt      DateTime?       @default(now())
  updatedAt      DateTime?       @updatedAt
}

model Category {
  id            Int        @id @default(autoincrement())
  slug          String     @unique
  name          String
  description   String?
  //
  parentId      Int?
  parent        Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subCategories Category[] @relation("CategoryHierarchy")
  events        Event[]
  //
  createdAt     DateTime?  @default(now())
  updatedAt     DateTime?  @updatedAt
}

enum Timezone {
  NONE
  UTC

  // North America
  EASTERN
  CENTRAL
  MOUNTAIN
  PACIFIC
  ALASKA
  HAWAII

  // South America
  ARGENTINA
  BRAZIL
  CHILE

  // Europe
  LONDON
  DUBLIN
  LISBON
  PARIS
  BERLIN
  ROME
  MADRID
  AMSTERDAM
  VIENNA
  STOCKHOLM
  OSLO
  COPENHAGEN
  HELSINKI
  ISTANBUL
  ATHENS
  MOSCOW

  // Africa
  LAGOS
  JOHANNESBURG
  NAIROBI
  CAIRO
  CASABLANCA

  // Middle East
  DUBAI
  RIYADH
  TEHRAN
  JERUSALEM

  // South Asia
  KARACHI
  DELHI
  COLOMBO
  DHAKA

  // East Asia
  BANGKOK
  SINGAPORE
  HONGKONG
  TAIPEI
  TOKYO
  SEOUL
  BEIJING

  // Oceania
  SYDNEY
  MELBOURNE
  AUCKLAND
  FIJI
}

enum VenueType {
  NONE
  PHYSICAL
  VIRTUAL
  HYBRID
  CUSTOM
}

enum RecurringPattern {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

enum RecurringEnd {
  NONE
  WEEKLY
  AFTEROCCURENCE
  UNTILDATE
  CUSTOM
}

enum LaunchStrategy {
  NONE
  DRAFT
  SOFT
  LAUNCH
  CUSTOM
}

enum Color {
  NONE
  RED
  BLUE
  GREEN
  PURPLE
  YELLOW
  PINK
  INDIGO
  ORANGE
}

enum RsvpResponse {
  NONE
  YESNO
  YESNOMAYBE
  CUSTOM
}

enum RsvpPlatform {
  NONE
  AMAZON
  TARGET
  WALMART
  BEDBATHBEYOND
  WILLIAMSSONOMA
  HONEYMOONFUND
  CUSTOM
}

enum RsvpTemplate {
  NONE
  DEFAULT
  FORMAL
  CASUAL
  MODERN
  CUSTOM
}

enum RsvpReminder {
  NONE
  STANDARD
  FREQUENT
  MINIMAL
  CUSTOM
}

enum ScheduleMode {
  NONE
  SIMPLE
  CONFERENCE
}

