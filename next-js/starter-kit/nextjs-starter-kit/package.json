{
  "name": "nextjs-starter-kit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "commit": "git add . && git commit -m 'update'",
    "push": "git add . && git commit -m 'update' && git push",
    "prisma:generate -f": "dotenv -e .env.local -- npx prisma generate --schema=./node_modules/.prisma/client/schema.prisma",
    "prisma:generate": "dotenv -e .env.local -- npx prisma generate",
    "prisma:migrate": "dotenv -e .env.local -- npx prisma migrate dev",
    "prisma:push": "dotenv -e .env.local -- npx prisma db push",
    "prisma:migrate:deploy": "dotenv -e .env.local -- npx prisma migrate deploy",
    "prisma:studio": "dotenv -e .env.local -- npx prisma studio",
    "prisma:pull": "dotenv -e .env.local -- npx prisma db pull",
    "postinstall -f": "prisma generate --no-engine && prisma migrate deploy",
    "_postinstall": "prisma generate --no-engine --schema=services/prisma/schema/schema.prisma && prisma migrate deploy --schema=services/prisma/schema/schema.prisma"
  },
  "prisma": {
    "schema": "services/prisma/schema/schema.prisma"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon": "^6.2.1",
    "@prisma/client": "^6.2.0",
    "@prisma/extension-accelerate": "^1.2.1",
    "@vercel/postgres": "^0.10.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "jose": "^5.9.6",
    "lucide-react": "^0.469.0",
    "next": "15.1.3",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "postcss": "^8",
    "prisma": "^6.2.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
